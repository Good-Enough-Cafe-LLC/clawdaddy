{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "isolatedModules": true,
    "types": ["node", "vitest/globals"],
  },
  "include": ["cli.ts", "src", "tests"],
  "exclude": ["node_modules", "dist", "web-cli"]
}