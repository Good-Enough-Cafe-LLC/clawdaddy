{
  "name": "clawdaddy-serve",
  "version": "1.0.12",
  "description": "Serve any LLM from your machine, accessible from anywhere via WebRTC",
  "bin": {
    "clawdaddy-serve": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "serve": "node dist/index.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --external:socket.io-client --external:@koush/wrtc"
  },
  "dependencies": {
    "@clawdaddy/core": "*",
    "@koush/wrtc": "^0.5.3",
    "commander": "^11.0.0",
    "ollama": "^0.5.0",
    "simple-peer": "^9.11.0",
    "socket.io-client": "^4.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/simple-peer": "^9.11.0",
    "esbuild": "^0.27.7",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
